# ===========================================
# Application
# ===========================================
NODE_ENV=development
PORT=3000

# ===========================================
# Database
# ===========================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/minitask_dev

# ===========================================
# Authentication (iron-session)
# ===========================================
# Must be at least 32 characters. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=replace-this-with-a-random-32-char-secret

# ===========================================
# Seed (superadmin created by prisma/seed.ts)
# ===========================================
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme-use-strong-password-in-prod
